{
    "configurations": [
        {
            "name": "STM32F103 (ARM GCC)",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "STM32F10X_MD",
                "USE_STDPERIPH_DRIVER",
                "HSE_VALUE=8000000",
                "__weak=__attribute__((weak))",
                "__CC_ARM"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "c99",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}